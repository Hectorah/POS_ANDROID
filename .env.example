# ============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Reemplaza los valores de ejemplo con tus datos reales
# 3. NO subas el archivo .env a Git (debe estar en .gitignore)
# ============================================================================

# 1. INFORMACIÓN DEL COMERCIO
COMERCIO_NOMBRE=TU COMERCIO AQUÍ
COMERCIO_RIF=J-000000000-0
COMERCIO_DIRECCION=DIRECCIÓN FISCAL AQUÍ
COMERCIO_TELEFONO=0414-0000000
COMERCIO_EMAIL=contacto@tucomercio.com

# 2. CONFIGURACIÓN FISCAL (SENIAT)
FISCAL_PREFIJO_NUMERO_CONTROL=00
FISCAL_RANGO_MAXIMO=9999999
FISCAL_UMBRAL_ALERTA=100
FISCAL_TASA_IVA=0.16
FISCAL_TASA_RETENCION_IVA=0.75

# 3. CONFIGURACIÓN DE UBII
UBII_CLIENT_ID=TU_X_CLIENT_ID_AQUI
UBII_CLIENT_DOMAIN=TU_DOMINIO_REGISTRADO
UBII_BASE_URL=https://botonc.ubiipagos.com

# 4. CONFIGURACIÓN DE PAGO MÓVIL
PAGO_MOVIL_TELEFONO=00584XXXXXXXXX
PAGO_MOVIL_CEDULA_RIF=V12345678
PAGO_MOVIL_ALIAS=P2C
PAGO_MOVIL_TIMEOUT=300
PAGO_MOVIL_POLLING_INTERVAL=5

# 5. CONFIGURACIÓN DE MONEDAS
TASA_CAMBIO_USD=36.50
TASA_CAMBIO_EUR=0.0
MONEDA_PRINCIPAL=USD

# 6. CONFIGURACIÓN DE LA APP
APP_ENVIRONMENT=development
APP_DEBUG_LOGS=true
APP_DEMO_MODE=false

# 7. CONFIGURACIÓN DE BASE DE DATOS
DB_NAME=POS_ANDROID.db
DB_VERSION=5
DB_AUTO_BACKUP=true
DB_BACKUP_INTERVAL_DAYS=7

# 8. CONFIGURACIÓN DE IMPRESIÓN
PRINTER_TYPE=none
PRINTER_PAPER_WIDTH=80
PRINTER_INCLUDE_LOGO=false
PRINTER_LOGO_PATH=assets/logos/klk.png

# 9. SUPABASE (Offline-First Sync)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui
